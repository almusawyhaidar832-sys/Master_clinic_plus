# انسخ إلى .env وعدّل القيم

AUTHENTICATION_API_KEY=change-me-to-a-long-random-secret-key
SERVER_URL=http://localhost:8080

DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:evolution@postgres:5432/evolution?schema=public

# Baileys — اتركه فارغاً لآخر إصدار واتساب (مهم لخطأ Couldn't link device)
CONFIG_SESSION_PHONE_VERSION=

CONFIG_SESSION_PHONE_CLIENT=Chrome
QRCODE_LIMIT=30

# يقلل ضغط الذاكرة عند الربط على Railway
DATABASE_SAVE_DATA_CHATS=false
DATABASE_SAVE_DATA_CONTACTS=false
DATABASE_SAVE_MESSAGE_UPDATE=false
SYNC_FULL_HISTORY=false

# CORS — ضع عنوان Next.js لاحقاً
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,DELETE
CORS_CREDENTIALS=true
