# عنوان يصل إليه الموبايل (باركود الحجوزات + QR) — IP الشبكة المحلية أو الدومين المنشور
# مثال تطوير: ipconfig ثم NEXT_PUBLIC_APP_URL=http://192.168.1.5:3000 و npm run dev:lan
NEXT_PUBLIC_APP_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# WhatsApp — Evolution API (انظر docs/WHATSAPP_EVOLUTION_SETUP.md)
# إنتاج: https://evolution-api-production-3797.up.railway.app
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_INSTANCE_NAME=master_clinic
WHATSAPP_PROVIDER=evolution

# بوابة المدير العام — لا ترفع .env.local إلى Git
ADMIN_EMAIL=your-email@gmail.com
PLATFORM_DEVELOPER_SECRET=change-me-min-32-chars-random-secret
# node scripts/hash-developer-password.mjs "your-password"  → ضع الناتج هنا:
PLATFORM_DEVELOPER_PASSWORD_HASH=
# بديل تطوير محلي فقط (أضعف أماناً):
# ADMIN_PASSWORD=

# Web Push — تنبيهات موبايل الطبيب حتى لو التطبيق مغلق (PWA)
# توليد المفاتيح: node scripts/generate-vapid-keys.mjs
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:your-email@example.com
