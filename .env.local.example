# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# WhatsApp — Evolution API (انظر docs/WHATSAPP_EVOLUTION_SETUP.md)
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_INSTANCE_NAME=master_clinic
WHATSAPP_PROVIDER=evolution

# بوابة المدير العام — لا ترفع .env.local إلى Git
ADMIN_EMAIL=your-email@gmail.com
PLATFORM_DEVELOPER_SECRET=change-me-min-32-chars-random-secret
# node scripts/hash-developer-password.mjs "your-password"  → ضع الناتج هنا:
PLATFORM_DEVELOPER_PASSWORD_HASH=
# بديل تطوير محلي فقط (أضعف أماناً):
# ADMIN_PASSWORD=
